<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/fraud-intelligence#"
         xml:base="http://www.semanticweb.org/fraud-intelligence#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xml="http://www.w3.org/XML/1998/namespace"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
  <owl:Ontology rdf:about="http://www.semanticweb.org/fraud-intelligence#">
    <rdfs:comment>Fraud Intelligence Ontology - Phase 1 minimal schema</rdfs:comment>
    <owl:versionInfo>1.0</owl:versionInfo>
  </owl:Ontology>

  <!-- Core Classes (Vertex Collections) -->

  <owl:Class rdf:about="#Person"/>
  <owl:Class rdf:about="#Organization"/>
  <owl:Class rdf:about="#WatchlistEntity"/>
  <owl:Class rdf:about="#BankAccount"/>
  <owl:Class rdf:about="#RealProperty"/>
  <owl:Class rdf:about="#Address"/>
  <owl:Class rdf:about="#DigitalLocation"/>

  <owl:Class rdf:about="#Transaction"/>
  <owl:Class rdf:about="#RealEstateTransaction">
    <rdfs:subClassOf rdf:resource="#Transaction"/>
  </owl:Class>

  <owl:Class rdf:about="#Document"/>
  <owl:Class rdf:about="#TitleDeed">
    <rdfs:subClassOf rdf:resource="#Document"/>
  </owl:Class>
  <owl:Class rdf:about="#NewsArticle">
    <rdfs:subClassOf rdf:resource="#Document"/>
  </owl:Class>
  <owl:Class rdf:about="#KYCRecord">
    <rdfs:subClassOf rdf:resource="#Document"/>
  </owl:Class>

  <owl:Class rdf:about="#GoldenRecord"/>

  <!-- Object Properties (Edge Collections) -->

  <owl:ObjectProperty rdf:about="#has_account">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#BankAccount"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#transferred_to">
    <rdfs:domain rdf:resource="#BankAccount"/>
    <rdfs:range rdf:resource="#BankAccount"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#related_to">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Person"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#associated_with">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Organization"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#resides_at">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Address"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#accessed_from">
    <rdfs:domain rdf:resource="#BankAccount"/>
    <rdfs:range rdf:resource="#DigitalLocation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#has_digital_location">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#DigitalLocation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#mentioned_in">
    <rdfs:range rdf:resource="#Document"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#registered_sale">
    <rdfs:domain rdf:resource="#RealProperty"/>
    <rdfs:range rdf:resource="#RealEstateTransaction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#buyer_in">
    <rdfs:range rdf:resource="#RealEstateTransaction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#seller_in">
    <rdfs:range rdf:resource="#RealEstateTransaction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#resolved_to">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#GoldenRecord"/>
  </owl:ObjectProperty>

  <!-- Datatype Properties (Document Attributes) -->

  <owl:DatatypeProperty rdf:about="#riskScore">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#riskDirect">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#riskInferred">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#riskPath">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#riskReasons">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#circleRateValue">
    <rdfs:domain rdf:resource="#RealProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#marketValue">
    <rdfs:domain rdf:resource="#RealProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#transactionValue">
    <rdfs:domain rdf:resource="#RealEstateTransaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#amount">
    <rdfs:domain rdf:resource="#Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#timestamp">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#transactionType">
    <rdfs:domain rdf:resource="#Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

</rdf:RDF>

