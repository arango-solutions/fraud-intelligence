ARANGO_URL=http://localhost:8529
ARANGO_USERNAME=root
ARANGO_PASSWORD=changeme
ARANGO_DOCKER_PASSWORD=changeme
ARANGO_DB=fraud-intelligence
ARANGO_PORT=8529

# Optional: verify TLS for https ARANGO_URL
ARANGO_VERIFY_SSL=true

# Analytics Catalog Configuration
# Enable tracking of all executions for compliance/audit (default: true)
FRAUD_ANALYSIS_ENABLE_CATALOG=true

# Workflow Configuration
# Enable parallel execution for faster analysis (default: false, safer for self-managed GAE)
FRAUD_ANALYSIS_PARALLELISM=false

# Maximum number of use cases to execute per run (default: 3)
FRAUD_ANALYSIS_MAX_EXECUTIONS=3

# Graph name to analyze (default: KnowledgeGraph)
FRAUD_GRAPH_NAME=KnowledgeGraph