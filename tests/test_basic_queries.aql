// Smoke queries (Phase 1)
// Run in arangosh after ingest, or paste into the ArangoDB UI query editor.

WITH Person, BankAccount, RealEstateTransaction, hasAccount, transferredTo, buyerIn, relatedTo

// 1) Account transfer traversal
FOR p IN Person
  FOR a IN 1..1 OUTBOUND p hasAccount
    FOR b IN 1..1 OUTBOUND a transferredTo
      LIMIT 5
      RETURN { person: p._key, from_account: a._key, to_account: b._key }

// 2) Social link + real estate traversal

FOR buyer IN Person
  FOR tx IN 1..1 OUTBOUND buyer buyerIn
    FOR related IN 1..1 ANY buyer relatedTo
      LIMIT 5
      RETURN { buyer: buyer._key, related_person: related._key, transaction: tx._key }

